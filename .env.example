PORT=5000
APP_URL=http://localhost:5000

# log
LOG_LEVEL=info
LOG_OUTPUT=console
LOG_FILE_PATH=logs/app.log

# ai chat model (legacy - NVIDIA)
NVIDIA_API_KEY=
NVIDIA_AI_MODEL=deepseek-ai/deepseek-v3.1
BASE_URL=https://integrate.api.nvidia.com/v1
TEMPERATURE=0.2
TOP_P=0.7
MAX_TOKENS=2048

# appwrite
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=

# gemini ai
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# file upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
